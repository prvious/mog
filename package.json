{
    "name": "mog",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "bunx concurrently -n pkg,workbench -c blue,green \"node ./scripts/build.js --watch\" \"pnpm --filter @mog/workbench dev\"",
        "format": "prettier --write resources .github/workflows",
        "format:check": "prettier --check resources .github/workflows",
        "build": "node ./scripts/build.js",
        "watch": "node ./scripts/build.js --watch"
    },
    "devDependencies": {
        "@floating-ui/dom": "^1.7.4",
        "@tailwindcss/cli": "^4.1.18",
        "brotli-size": "^4.0.0",
        "esbuild": "^0.27.2",
        "playwright": "^1.57.0",
        "prettier": "^3.7.4",
        "prettier-plugin-blade": "github:prvious/prettier-plugin-blade#main",
        "prettier-plugin-tailwindcss": "^0.5.14",
        "tailwindcss": "^4.0.0",
        "tw-animate-css": "^1.4.0"
    },
    "pnpm": {
        "overrides": {
            "prettier-plugin-blade": "github:prvious/prettier-plugin-blade#main"
        }
    }
}
