{
    "name": "prvious/mog",
    "description": "Component library for livewire based application",
    "homepage": "https://mog.prvious.dev",
    "license": "MIT",
    "authors": [
        {
            "name": "Clovis Muneza",
            "email": "clovis@prvious.dev"
        }
    ],
    "keywords": [
        "laravel",
        "livewire",
        "component",
        "ui"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "blade-ui-kit/blade-icons": "^1.8",
        "mallardduck/blade-lucide-icons": "^1.26",
        "livewire/livewire": "^4.0",
        "tales-from-a-dev/tailwind-merge-php": "^0.1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.22",
        "pestphp/pest": "^4.1",
        "phpstan/phpstan": "^2.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "orchestra/testbench": "^10.9",
        "pestphp/pest-plugin-browser": "^4.0",
        "orchestra/pest-plugin-testbench": "^4.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Mog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mog\\MogServiceProvider"
            ],
            "aliases": {
                "Mog": "Mog\\Mog"
            }
        }
    },
    "scripts": {
        "lint": [
            "@php vendor/bin/pint --ansi"
        ],
        "lint:check": [
            "@php vendor/bin/pint --test"
        ],
        "test": [
            "vendor/bin/pest --ci"
        ],
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}